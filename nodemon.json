{
  "watch": [
    ".",
    "config",
    "routes",
    "controller",
    "modal",
    "middleware",
    "utils",
    "scripts"
  ],
  "ext": "ts,json",
  "ignore": ["node_modules", "dist", ".git", ".env", "**/*.spec.ts"],
  "exec": "ts-node server.ts",
  "delay": 1000,
  "env": {
    "NODE_ENV": "development"
  }
}
