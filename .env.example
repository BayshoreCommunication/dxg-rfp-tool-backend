# DXG RFP Tool Backend (example)
# Copy to .env on your server and fill real values. Do not commit .env.

NODE_ENV=production
PORT=8000

# Database
MONGODB_URL=mongodb://127.0.0.1:27017/dxg_rfp_tool_db

# Auth
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRE=30d
ADMIN_SIGNUP_SECRET=replace-with-a-strong-admin-secret

# URLs (used for email links/tracking)
FRONTEND_URL=https://dxg-rfp-tool-dashboard.vercel.app
BACKEND_URL=https://api.dxg-agency.com

# Email (optional but recommended)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_MAIL=no-reply@example.com
SMTP_PASSWORD=replace-with-smtp-password

# OpenAI (required for /api/extract-proposal)
OPENAI_API_KEY=replace-with-openai-api-key

# DigitalOcean Spaces (optional, for cloud uploads)
DO_SPACES_BUCKET=your-bucket
DO_SPACES_REGION=nyc3
DO_SPACES_KEY=your-key
DO_SPACES_SECRET=your-secret
DO_FOLDER_NAME=DXG-RFP-Tool

# Optional bootstrap admin
SUPER_USER_EMAIL=admin@example.com
SUPER_USER_PASSWORD=replace-with-strong-password
SUPER_USER_NAME=Admin

